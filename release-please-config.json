{
    "packages": {
        "packages/host": {
            "release-type": "node",
            "package-name": "@reactronx/host",
            "bump-minor-pre-major": true,
            "bump-patch-for-minor-pre-major": true
        },
        "packages/renderer": {
            "release-type": "node",
            "package-name": "@reactronx/renderer",
            "bump-minor-pre-major": true,
            "bump-patch-for-minor-pre-major": true
        },
        "packages/preload": {
            "release-type": "node",
            "package-name": "@reactronx/preload",
            "bump-minor-pre-major": true,
            "bump-patch-for-minor-pre-major": true
        }
    },
    "plugins": [
        {
            "type": "linked-versions",
            "groupName": "reactronx",
            "components": ["@reactronx/host", "@reactronx/guest", "@reactronx/guest-preload"]
        }
    ]
}
